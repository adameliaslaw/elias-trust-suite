// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: /clients/{clientId}
// Fields:
//   - uid: string (required) - Firebase Auth uid of the owning user.
//   - name: string (required) - The full name of the client.
//   - matterDescription: string (optional) - A brief description of the legal matter.
//   - balance: number (optional) - The current balance held in trust for this client.
//
// Collection: /transactions/{transactionId}
// Fields:
//   - uid: string (required) - Firebase Auth uid of the owning user.
//   - clientId: string (optional) - Reference to the Client entity.
//   - clientName: string (optional) - Denormalized client name for sorting.
//   - date: string (required, format: date) - The date of the transaction (issue date for checks).
//   - clearDate: string (optional, format: date) - The date the transaction cleared the bank.
//   - amount: number (required) - The transaction amount (positive for receipts, negative for disbursements).
//   - type: string (required, enum: ["receipt", "disbursement"]) - The type of transaction.
//   - checkNumber: string (optional) - The check number for disbursements.
//   - description: string (optional) - A description of the transaction.
//   - month: string (required) - The reconciliation month (YYYY-MM).
//
// Collection: /reconciliations/{periodId}   (periodId = "{accountId}__{month}", issue #15)
// Fields:
//   - uid: string (required) - Firebase Auth uid of the owning user.
//   - accountId: string (required) - The trust account this period belongs to.
//   - month: string (required) - The reconciliation month (YYYY-MM).
//   - bankBalance: number (required) - The balance per the bank statement.
//   - bookBalance: number (required) - The balance per the firm's books (ledger).
//   - clientBalanceTotal: number (required) - The total of all individual client ledger balances.
//   - isReconciled: boolean (required) - Whether the three balances match exactly (integer cents).
//   - outstandingChecksTotal: number (optional) - Total of outstanding checks at month end.
//   - depositsInTransitTotal: number (optional) - Total of deposits in transit at month end.
//
// Collection: /statementBalances/{periodId}  (periodId = "{accountId}__{month}", issue #15)
// Fields:
//   - uid: string (required) - Firebase Auth uid of the owning user.
//   - accountId: string (required) - The trust account this balance belongs to.
//   - month: string (required) - The statement month (YYYY-MM).
//   - balance: number (required) - The ending balance from the bank statement.
//
// Reconciliation lifecycle (Phase 3, #14): /reconciliations docs gain a
// `lifecycleStatus` ('draft' | 'finalized'), `version`, and `contentHash`. A
// FINALIZED month is immutable: transactions and statementBalances dated within
// it are refused (see periodFinalized()). /reconciliationPackets/{accountId__
// month__vN} holds the immutable, seven-year retained packet (Rule 1:21-6),
// create-only. /sourceStatements/{accountId__sha256} retains source-document
// provenance (name + content hash + covered months) for packet reproduction.
//
// Multi-tenancy (issue #15): /firms, /memberships, /trustAccounts model the
// firm → membership → account hierarchy. The suite runs single-firm today by
// deriving a per-user default trust account id ("trust__{uid}"), so period doc
// ids are account-scoped and can never collide across users or accounts — the
// pre-Phase-2 bare-month ids ("2026-07") let the first writer own a month for
// everyone. NOTE: these rules are still UNDEPLOYED — deployment is deferred to
// Phase 8 / #27 (firebase deploy --only firestore:rules).
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "adam@adameliaslaw.com" && request.auth.token.email_verified == true));
    }

    // ---------------------------------------------------------------
    // Ownership (audit issue #1)
    // Every user-data document carries a `uid` field. Reads, updates,
    // and deletes are restricted to the owner; creates/updates must
    // stamp the caller's own uid (prevents writing as someone else).
    // ---------------------------------------------------------------
    function isOwner() {
      return isAuthenticated() &&
        resource.data.uid is string &&
        resource.data.uid == request.auth.uid;
    }

    function isOwnerWrite() {
      return isAuthenticated() &&
        request.resource.data.keys().hasAll(['uid']) &&
        request.resource.data.uid is string &&
        request.resource.data.uid == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidDateString(dateStr) {
      return dateStr is string &&
        dateStr.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidClient(data) {
      return hasRequiredFields(['name', 'uid']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('matterDescription' in data) || (data.matterDescription is string && data.matterDescription.size() < 500)) &&
             (!('balance' in data) || data.balance is number);
    }

    function isValidTransaction(data) {
      return hasRequiredFields(['date', 'amount', 'type', 'month', 'uid']) &&
             data.uid is string &&
             isValidDateString(data.date) &&
             data.amount is number &&
             data.type in ['receipt', 'disbursement'] &&
             data.month is string && data.month.matches("^\\d{4}-\\d{2}$") &&
             (!('clientId' in data) || (data.clientId is string)) &&
             (!('clientName' in data) || (data.clientName is string && data.clientName.size() < 100)) &&
             (!('clearDate' in data) || isValidDateString(data.clearDate)) &&
             (!('checkNumber' in data) || (data.checkNumber is string && data.checkNumber.size() < 20)) &&
             (!('description' in data) || (data.description is string && data.description.size() < 500));
    }

    function isValidReconciliation(data) {
      return hasRequiredFields(['month', 'accountId', 'bankBalance', 'bookBalance', 'clientBalanceTotal', 'isReconciled', 'uid']) &&
             data.uid is string &&
             data.accountId is string && data.accountId.size() > 0 &&
             data.month is string && data.month.matches("^\\d{4}-\\d{2}$") &&
             data.bankBalance is number &&
             data.bookBalance is number &&
             data.clientBalanceTotal is number &&
             data.isReconciled is bool &&
             (!('outstandingChecksTotal' in data) || data.outstandingChecksTotal is number) &&
             (!('depositsInTransitTotal' in data) || data.depositsInTransitTotal is number) &&
             // Lifecycle fields (Phase 3, #14): a period is 'draft' or 'finalized'.
             (!('lifecycleStatus' in data) || data.lifecycleStatus in ['draft', 'finalized']) &&
             (!('version' in data) || (data.version is int && data.version >= 1)) &&
             (!('contentHash' in data) || (data.contentHash is string && data.contentHash.size() == 64));
    }

    // A period is LOCKED once its reconciliation record is finalized (#14).
    // Every trust account here is per-user (accountId = "trust__{uid}"), so a
    // transaction's lock is decided by the reconciliation doc for its month.
    // (Rules stay UNDEPLOYED — see header note — so client-side lifecycle.ts is
    // the live enforcement today; this makes the lock server-authoritative on deploy.)
    function periodDocPath(month) {
      return /databases/$(database)/documents/reconciliations/$(('trust__' + request.auth.uid) + '__' + month);
    }
    function periodFinalized(month) {
      return exists(periodDocPath(month)) &&
             get(periodDocPath(month)).data.lifecycleStatus == 'finalized';
    }

    // The immutable, retained finalized packet (Rule 1:21-6 seven-year record).
    function isValidReconciliationPacket(data) {
      return hasRequiredFields(['accountId', 'month', 'version', 'status', 'contentHash', 'uid']) &&
             data.uid is string &&
             data.accountId is string && data.accountId.size() > 0 &&
             data.month is string && data.month.matches("^\\d{4}-\\d{2}$") &&
             data.version is int && data.version >= 1 &&
             data.status == 'finalized' &&
             data.contentHash is string && data.contentHash.size() == 64;
    }

    function isValidSourceStatement(data) {
      return hasRequiredFields(['accountId', 'name', 'sha256', 'bytes', 'uid']) &&
             data.uid is string &&
             data.accountId is string && data.accountId.size() > 0 &&
             data.name is string && data.name.size() < 300 &&
             data.sha256 is string && data.sha256.size() == 64 &&
             data.bytes is int && data.bytes >= 0;
    }

    function isValidStatementBalance(data) {
      return hasRequiredFields(['balance', 'accountId', 'month', 'uid']) &&
             data.uid is string &&
             data.accountId is string && data.accountId.size() > 0 &&
             data.month is string && data.month.matches("^\\d{4}-\\d{2}$") &&
             data.balance is number;
    }

    // Account-scoped period doc id must be "{accountId}__{month}" (issue #15):
    // ties the document key to its account so a bare month can no longer be
    // owned by the first writer for everyone.
    function isScopedPeriodId(periodId, data) {
      return periodId == data.accountId + '__' + data.month;
    }

    function isValidTrustAccount(data) {
      return hasRequiredFields(['name', 'firmId', 'uid']) &&
             data.uid is string &&
             data.firmId is string && data.firmId.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 120;
    }

    function isValidMembership(data) {
      return hasRequiredFields(['firmId', 'uid', 'role']) &&
             data.uid is string &&
             data.firmId is string && data.firmId.size() > 0 &&
             data.role in ['owner', 'admin', 'member'];
    }

    function isValidFirm(data) {
      return hasRequiredFields(['name', 'uid']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /clients/{clientId} {
      allow read: if isOwner();
      allow create: if isOwnerWrite() && isValidClient(request.resource.data);
      allow update: if isOwner() && isOwnerWrite() && isValidClient(request.resource.data);
      allow delete: if isOwner();
    }

    match /transactions/{transactionId} {
      allow read: if isOwner();
      // A transaction dated within a FINALIZED month cannot be created, edited,
      // moved, or deleted (#14). An edit that changes the date must clear the
      // lock for BOTH the old and the new month.
      allow create: if isOwnerWrite() && isValidTransaction(request.resource.data) &&
        !periodFinalized(request.resource.data.month);
      allow update: if isOwner() && isOwnerWrite() && isValidTransaction(request.resource.data) &&
        !periodFinalized(resource.data.month) && !periodFinalized(request.resource.data.month);
      allow delete: if isOwner() && !periodFinalized(resource.data.month);
    }

    match /reconciliations/{periodId} {
      allow read: if isOwner();
      allow create: if isOwnerWrite() && isValidReconciliation(request.resource.data) &&
        isScopedPeriodId(periodId, request.resource.data);
      allow update: if isOwner() && isOwnerWrite() && isValidReconciliation(request.resource.data) &&
        isScopedPeriodId(periodId, request.resource.data);
      allow delete: if isOwner();
    }

    match /statementBalances/{periodId} {
      allow read: if isOwner();
      // A finalized month freezes its statement balance — no create/update into it.
      allow create: if isOwnerWrite() && isValidStatementBalance(request.resource.data) &&
        isScopedPeriodId(periodId, request.resource.data) &&
        !periodFinalized(request.resource.data.month);
      allow update: if isOwner() && isOwnerWrite() && isValidStatementBalance(request.resource.data) &&
        isScopedPeriodId(periodId, request.resource.data) &&
        !periodFinalized(resource.data.month);
      allow delete: if isOwner() && !periodFinalized(resource.data.month);
    }

    // ---------------------------------------------------------------
    // Retained finalized packets (#14 / #22): the immutable, seven-year
    // reconciliation record (Rule 1:21-6). CREATE-ONLY — like the audit chain,
    // rules cannot verify the sha256 contentHash but they CAN make the record
    // immutable: no update, no delete, ever. Doc id is "{accountId}__{month}__v{n}".
    // ---------------------------------------------------------------
    match /reconciliationPackets/{packetId} {
      allow read: if isOwner();
      allow create: if isOwnerWrite() && isValidReconciliationPacket(request.resource.data);
      allow update, delete: if false;  // a finalized packet is never altered
    }

    // Retained source-statement metadata (name + content hash + covered months).
    // Content-addressed doc id ("{accountId}__{sha256}"); re-import overwrites
    // with identical bytes. Not deletable — it is provenance for a finalized packet.
    match /sourceStatements/{sourceId} {
      allow read: if isOwner();
      allow create, update: if isOwnerWrite() && isValidSourceStatement(request.resource.data);
      allow delete: if false;
    }

    // ---------------------------------------------------------------
    // Multi-tenant hierarchy (issue #15): firms → memberships → trust
    // accounts. Ownership is by uid today (single firm per user); the
    // structure is modeled so firm-membership scoping can layer on for SaaS
    // (Decision 1 = C) without a schema change. UNDEPLOYED — see header note.
    // ---------------------------------------------------------------
    match /firms/{firmId} {
      allow read: if isOwner();
      allow create: if isOwnerWrite() && isValidFirm(request.resource.data);
      allow update: if isOwner() && isOwnerWrite() && isValidFirm(request.resource.data);
      allow delete: if isOwner();
    }

    match /memberships/{membershipId} {
      allow read: if isOwner();
      allow create: if isOwnerWrite() && isValidMembership(request.resource.data);
      allow update: if isOwner() && isOwnerWrite() && isValidMembership(request.resource.data);
      allow delete: if isOwner();
    }

    match /trustAccounts/{accountId} {
      allow read: if isOwner();
      allow create: if isOwnerWrite() && isValidTrustAccount(request.resource.data);
      allow update: if isOwner() && isOwnerWrite() && isValidTrustAccount(request.resource.data);
      allow delete: if isOwner();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin();
    }

    // ===============================================================
    // Tamper-evident audit chain (@elias/audit wiring)
    //
    // auditEntries: the sealed hash-chained history. CREATE-ONLY — rules
    // cannot verify SHA-256 linkage, but they CAN make history immutable:
    // no update, no delete. verify-on-open detects any out-of-band change.
    // auditMeta/{uid}: the chain head — the compare-and-swap cursor that
    // serializes concurrent tabs/devices via Firestore transactions.
    // ===============================================================
    function isValidAuditEntry(data) {
      return hasRequiredFields(['seq', 'timestamp', 'type', 'payload', 'prevHash', 'hash', 'uid']) &&
             data.uid is string &&
             data.seq is int && data.seq >= 0 &&
             data.timestamp is string && data.timestamp.size() < 40 &&
             data.type is string && data.type.size() < 80 &&
             data.payload is map &&
             data.prevHash is string && data.prevHash.size() <= 64 &&
             data.hash is string && data.hash.size() == 64;
    }

    match /auditEntries/{entryId} {
      allow read: if isOwner();
      allow create: if isOwnerWrite() && isValidAuditEntry(request.resource.data);
      allow update, delete: if false;   // history is append-only
    }

    match /auditMeta/{docId} {
      allow read: if isAuthenticated() && docId == request.auth.uid;
      allow create, update: if isAuthenticated() && docId == request.auth.uid &&
        request.resource.data.keys().hasOnly(['seq', 'hash', 'uid', 'updatedAt']) &&
        request.resource.data.seq is int && request.resource.data.seq >= 0 &&
        request.resource.data.hash is string && request.resource.data.hash.size() == 64 &&
        request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
  }
}
